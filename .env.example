# AetherDesk Call Center Platform - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
#
# LOCAL DEV QUICK START:
#   1. Copy this file to .env
#   2. Run: python run_call_center.py
#   3. Open http://127.0.0.1:3001 in Chrome
#
# NOTE: For local dev, USE_POSTGRES=false uses SQLite instead of PostgreSQL

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_USER=aetherdesk_admin
DB_PASSWORD=your-secure-database-password-here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aetherdesk

# Set to "false" for local dev (uses SQLite), "true" for production (uses PostgreSQL)
USE_POSTGRES=false

# SQLite path (local dev only)
SQLITE_PATH=aetherdesk.db

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# FONOSTER CONFIGURATION
# ============================================
FONOSTER_API_KEY=your-fonoster-api-key
FONOSTER_API_SECRET=your-fonoster-api-secret
FONOSTER_HOST=localhost
FONOSTER_PORT=50061

# ============================================
# FREESWITCH CONFIGURATION
# ============================================
FS_HOST=localhost
FS_PORT=5060
FS_ESL_HOST=localhost
FS_ESL_PORT=8021
FS_ESL_PASSWORD=ClueCon

# ============================================
# AI / SPEECH SERVICES
# ============================================

# Speech-to-Text (STT)
STT_ENGINE=deepgram
DEEPGRAM_API_KEY=REPLACE_WITH_DEEPGRAM_API_KEY

# Text-to-Speech (TTS) - comma-separated for fallback chain
# Chatterbox (CPU) is tried first, Qwen3-TTS (GPU) is fallback
TTS_ENGINE=chatterbox,qwen3
CHATTERBOX_API_URL=http://chatterbox:5001
QWEN_API_URL=http://qwen3-tts:8000
QWEN_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice

# Language Model (LLM) for Agent Intelligence
LLM_PROVIDER=groq
GROQ_API_KEY=REPLACE_WITH_GROQ_API_KEY

# ============================================
# APPLICATION SECURITY (REQUIRED - app won't start without these)
# ============================================
# Generate a proper key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=REPLACE_ME_WITH_A_STRONG_FERNET_KEY
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=REPLACE_ME_WITH_A_STRONG_JWT_SECRET
JWT_EXPIRATION=24h
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBSOCKET_SECRET_KEY=REPLACE_ME_WITH_A_STRONG_WS_SECRET
# Internal service-to-service API key (used by verify_api_key dependency)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_API_KEY=REPLACE_ME_WITH_A_STRONG_INTERNAL_KEY

# ============================================
# GOOGLE CLOUD CONFIGURATION
# ============================================
GCP_PROJECT_ID=aetherdesk
GCP_PROJECT_NAME=AetherDesk
GKE_CLUSTER_NAME=aetherdesk-cluster
GKE_REGION=us-east1
GKE_NODE_COUNT=2
GKE_MACHINE_TYPE=e2-standard-4

# ============================================
# COMPLIANCE & PRIVACY
# ============================================
GDPR_COMPLIANT=true
HIPAA_COMPLIANT=true
DATA_RESIDENCY=us-east1
ENCRYPTION_AT_REST=true
ENCRYPTION_IN_TRANSIT=true
CALL_RECORDING_RETENTION_DAYS=365

# ============================================
# TWILIO VOICE INTEGRATION
# ============================================
# Used when FONOSTER is not configured (dev / staging default).
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+18556874690
# Publicly reachable base URL for Twilio to POST webhook events back to.
# Local dev: use ngrok (e.g. https://abc123.ngrok.io) or set to http://localhost:8000
# Production: set to your API domain (e.g. https://api.aetherdesk.com)
TWILIO_WEBHOOK_BASE=http://localhost:8000

# ============================================
# SIP TRUNKING (Alternative to Twilio REST API)
# ============================================
# Only required when using Fonoster + FreeSWITCH with an external SIP trunk.
# (e.g., Flowroute, Telnyx, Twilio Elastic SIP)
SIP_TRUNK_PROVIDER=your-provider
SIP_TRUNK_HOST=your-sip-trunk-host
SIP_TRUNK_PORT=5060
SIP_TRUNK_USERNAME=your-sip-username
SIP_TRUNK_PASSWORD=your-sip-password
SIP_TRUNK_FROM=your-sip-phone-number

# ============================================
# PLATFORM SETTINGS
# ============================================
APP_ENV=development
APP_URL=http://localhost:3001
API_URL=http://localhost:8000
MAX_CONCURRENT_CALLS_PER_TENANT=10
AGENT_IDLE_TIMEOUT=300

# ============================================
# OBSERVABILITY
# ============================================
# Sentry DSN for error tracking (optional for dev, required for prod)
SENTRY_DSN=
# AgentOps API key for AI agent observability (optional)
AGENTOPS_API_KEY=

# ============================================
# LOGGING
# ============================================
# Log format: "json" for structured JSON (production), "text" for human-readable (dev)
LOG_FORMAT=json
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================
# DEVELOPMENT OPTIONS
# ============================================
# Enable/disable dev features
ENABLE_DEBUG_MODE=true
ENABLE_TEST_ENDPOINTS=true

# ============================================
# STRIPE (Phase 2 Billing)
# ============================================
# Leave STRIPE_SECRET_KEY empty to run in MOCK mode (dev only)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=price_starter_monthly
STRIPE_PRICE_PRO=price_pro_monthly
STRIPE_PRICE_ENTERPRISE=price_enterprise_monthly
STRIPE_SUCCESS_URL=http://localhost:5173/billing?success=true
STRIPE_CANCEL_URL=http://localhost:5173/billing?canceled=true