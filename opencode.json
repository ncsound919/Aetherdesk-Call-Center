{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "production-readiness": {
      "description": "Python testing and code quality specialist for production readiness improvements",
      "mode": "subagent",
      "model": "deepseek/deepseek-v4-flash",
      "permission": {
        "edit": "allow",
        "bash": {
          "git *": "allow",
          "python *": "allow",
          "pytest *": "allow",
          "npx *": "allow",
          "cd *": "allow",
          "*": "ask"
        }
      }
    }
  }
}
